{
  "name": "@pinkbrain-lp/backend",
  "version": "0.1.0",
  "description": "PinkBrain LP Backend - Fee-compounding engine for Bags.fm",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "node ../node_modules/tsx/dist/cli.mjs watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests scripts --ext .ts",
    "clean": "rimraf dist",
    "script": "node ../node_modules/tsx/dist/cli.mjs scripts/test-cycle.ts",
    "cli": "node ../node_modules/tsx/dist/cli.mjs scripts/cli.ts",
    "agent": "node ../node_modules/tsx/dist/cli.mjs scripts/agent.ts",
    "bootstrap-token": "node ../node_modules/tsx/dist/cli.mjs scripts/bootstrap-token.ts",
    "remote-signer": "node ../node_modules/tsx/dist/cli.mjs scripts/remote-signer.ts",
    "smoke": "node ../node_modules/tsx/dist/cli.mjs scripts/smoke-test.ts"
  },
  "dependencies": {
    "@bagsfm/bags-sdk": "^1.3.4",
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.1",
    "@meteora-ag/cp-amm-sdk": "^1.4.0",
    "@solana/spl-token": "^0.4.13",
    "@solana/web3.js": "^1.95.0",
    "better-sqlite3": "^9.4.0",
    "bn.js": "^5.2.1",
    "bs58": "^6.0.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "node-cron": "^3.0.3",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/bn.js": "^5.1.6",
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "rimraf": "^5.0.5",
    "tsx": "^4.20.6",
    "typescript": "^5.3.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
