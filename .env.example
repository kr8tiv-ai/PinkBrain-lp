# PinkBrain LP Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED
# ===========================================

# Bags.fm API Key (get from https://bags.fm/developer)
BAGS_API_KEY=your_bags_api_key_here

# ===========================================
# OPTIONAL (will auto-generate if not provided)
# ===========================================

# Helius API Key (for enhanced RPC and DAS API)
# If not provided, will use public Solana RPC
HELIUS_API_KEY=your_helius_api_key_here

# Custom Helius RPC URL (optional, auto-generated from API key)
# HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# ===========================================
# NETWORK CONFIGURATION
# ===========================================

# Solana Network: mainnet-beta or devnet
SOLANA_NETWORK=mainnet-beta

# ===========================================
# FEE THRESHOLD CONFIGURATION
# ===========================================

# Minimum SOL amount before fee claiming triggers
# Default: 7 SOL
FEE_THRESHOLD_SOL=7

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================

# Node Environment: development, production, test
NODE_ENV=development

# Log Level: debug, info, warn, error
LOG_LEVEL=info
