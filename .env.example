# PinkBrain LP Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Required: Bags.fm API
# ===========================================
# Get your API key from https://bags.fm/developers
BAGS_API_KEY=your_bags_api_key_here

# Optional: Override default API URL
# BAGS_API_BASE_URL=https://public-api-v2.bags.fm/api/v1

# ===========================================
# Required: Helius RPC
# ===========================================
# Get your API key from https://helius.dev
HELIUS_API_KEY=your_helius_api_key_here

# Optional: Override RPC URL (defaults to Helius mainnet)
# HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_key

# ===========================================
# Solana Network Configuration
# ===========================================
# Options: mainnet-beta, devnet
SOLANA_NETWORK=mainnet-beta

# ===========================================
# Fee Claiming Threshold
# ===========================================
# Minimum SOL required before compounding triggers
# Default: 7 SOL
FEE_THRESHOLD_SOL=7

# ===========================================
# API Server
# ===========================================
# Port for the Fastify HTTP API
PORT=3001
HOST=0.0.0.0

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://bags.fm,https://www.bags.fm

# Bearer token used for direct programmatic API access and optional bootstrap minting.
API_AUTH_TOKEN=change_me

# Session cookie signing secret for browser-safe operator sessions.
# Defaults to API_AUTH_TOKEN when omitted, but set a dedicated value in production.
SESSION_SECRET=
SESSION_TTL_HOURS=12

# Bootstrap-token settings for browser sign-in links.
# Operators should mint short-lived bootstrap tokens instead of typing API_AUTH_TOKEN into the browser.
BOOTSTRAP_TOKEN_SECRET=
BOOTSTRAP_TOKEN_TTL_MINUTES=10

# Legacy browser login with API_AUTH_TOKEN is disabled by default.
ALLOW_BROWSER_OPERATOR_TOKEN_LOGIN=false

# Optional: Bags Agent auth flow. Wallet export is disabled by default and must
# be explicitly enabled as a break-glass fallback.
BAGS_AGENT_USERNAME=
BAGS_AGENT_JWT=
BAGS_AGENT_WALLET_ADDRESS=
ALLOW_AGENT_WALLET_EXPORT=false

# Base58 or JSON-array secret key used by the backend worker/scheduler to sign
# transactions when running outside the Bags iframe runtime.
SIGNER_PRIVATE_KEY=

# Preferred production mode: delegate signing to an isolated remote signer service.
REMOTE_SIGNER_URL=
REMOTE_SIGNER_AUTH_TOKEN=
REMOTE_SIGNER_TIMEOUT_MS=10000

# Remote signer host settings (used only by `npm run remote-signer -w backend`)
REMOTE_SIGNER_HOST=127.0.0.1
REMOTE_SIGNER_PORT=3101
REMOTE_SIGNER_RPC_URL=
REMOTE_SIGNER_PRIVATE_KEY=

# Runtime execution controls
DRY_RUN=false
EXECUTION_KILL_SWITCH=false
MAX_DAILY_RUNS=0
MAX_CLAIMABLE_SOL_PER_RUN=0

# Optional smoke-test inputs
# SMOKE_WALLET=
# SMOKE_QUOTE_INPUT_MINT=So11111111111111111111111111111111111111112
# SMOKE_QUOTE_OUTPUT_MINT=
# SMOKE_QUOTE_AMOUNT=1000000
# SMOKE_EXPORT_AGENT_SIGNER=false

# ===========================================
# Database
# ===========================================
# Path to SQLite database file
# DB_PATH=./data/pinkbrain.db

# ===========================================
# Application Settings
# ===========================================
# Options: development, production, test
NODE_ENV=development

# Options: debug, info, warn, error
LOG_LEVEL=info
